rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Coach gate — reads the custom Auth claim set by the `setUserRole`
    // Cloud Function. No cross-service Firestore reads (those don't work
    // in Storage rules). This is the canonical way to gate per-role
    // access at the bucket level.
    function isCoach() {
      return request.auth != null
             && request.auth.token.role in ['coach', 'admin'];
    }

    // ─── Check-in photos: check-ins/{userId}/** ───────────────
    // Owner-only reads. Coaches access photos via signed download URLs
    // stored in Firestore checkIn docs — not via direct Storage reads.
    match /check-ins/{userId}/{allPaths=**} {

      allow read: if request.auth != null
                  && request.auth.uid == userId;

      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource != null
                   && request.resource.contentType.matches('image/.*')
                   && request.resource.size <= 10 * 1024 * 1024;

      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // Chat image attachments.
    match /chat-images/{senderId}/to/{receiverId}/{allPaths=**} {

      allow read: if request.auth != null
                  && (request.auth.uid == senderId
                      || request.auth.uid == receiverId
                      || isCoach());

      allow write: if request.auth != null
                   && request.auth.uid == senderId
                   && request.resource != null
                   && request.resource.contentType.matches('image/.*')
                   && request.resource.size <= 10 * 1024 * 1024;

      allow delete: if request.auth != null
                    && (request.auth.uid == senderId || isCoach());
    }

    // Legacy video PDFs: video-pdfs/{videoId}/**
    // Reads: any signed-in user (so attached PDFs play in the lesson view).
    // Writes/deletes: coach/admin only via the custom claim.
    match /video-pdfs/{videoId}/{allPaths=**} {

      allow read: if request.auth != null;

      allow write: if isCoach()
                   && request.resource != null
                   && request.resource.contentType.matches('application/pdf.*')
                   && request.resource.size <= 50 * 1024 * 1024;

      allow delete: if isCoach();
    }

    // ─── Academy lesson resources ─────────────────────────────
    match /course-resources/{courseId}/{lessonId}/{allPaths=**} {

      allow read: if request.auth != null;

      allow write: if isCoach()
                   && request.resource != null
                   && request.resource.contentType.matches('application/pdf.*')
                   && request.resource.size <= 50 * 1024 * 1024;

      allow delete: if isCoach();
    }

    // ─── Catch-all: deny everything else ─────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
