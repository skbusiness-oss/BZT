## 12. REP SCHEME PARSER (programUtils.ts)

### Parse Logic
```typescript
function parseRepScheme(reps: string, goal: WorkoutGoal): RepSchemeInfo {

  // DUAL SET: '5-9 + 10-15'
  if (reps.includes('+')) → {
    type: 'dual',
    set1: { reps: s1, weight: '~80%', label: 'HEAVY' },
    set2: { reps: s2, weight: '~50%', label: 'PUMP' },
    set1Ar: { label: 'ثقيل' },
    set2Ar: { label: 'ضخ' }
  }

  // PERCENTAGE: '5 @80%' or '3 @85-88%'
  if (reps.includes('@')) → {
    type: 'percentage',
    reps: repCount,
    percentage: pct,
    explanation: `Use ${pct} of your 1 rep max`,
    explanationAr: `استخدم ${pct} من أقصى طاقتك`
  }

  // RECOMP DUAL: 'S1×6, S2×12' or 'S1×6@80%, S2×12@65%'
  if (reps.includes('S1') && reps.includes('S2')) → {
    type: 'recomp',
    explanation: 'Set 1 strength. Set 2 volume.',
    explanationAr: 'الشوط الأول: قوة. الشوط الثاني: حجم.'
  }

  // FAILURE: 'Until Failure' or 'Max'
  if failure keyword → {
    type: 'failure',
    explanation: 'Go until you cannot complete another clean rep',
    explanationAr: 'استمر حتى لا تستطيع إكمال تكرار نظيف'
  }

  // TIMED: '40s Work / 20s Rest'
  if timed keyword → {
    type: 'timed',
    explanation: 'Work for the full time. Quality over speed.',
    explanationAr: 'اعمل طوال الوقت المحدد. الجودة قبل السرعة.'
  }

  // STANDARD: '10-15', '8-12'
  default → {
    type: 'standard',
    explanation: goalExplanations[goal],
    explanationAr: goalExplanationsAr[goal]
  }
}
```

