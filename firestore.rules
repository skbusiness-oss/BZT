rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────
    // Role is always read from the user's Firestore doc — no hardcoded emails.
    // AuthContext creates the doc on first login before any other writes.
    function role() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'community';
    }

    function isCoach() {
      // Prefer the custom Auth claim (set by `setUserRole` Cloud Function) —
      // matches Storage rules, no Firestore read. Falls back to the
      // Firestore role for accounts whose claim hasn't been bootstrapped
      // yet. The fallback is SAFE here because the self-create rule on
      // users/{uid} (below) restricts owner-write to role == 'community'
      // — so a Firestore role of 'coach'/'admin' can only have been
      // written by an existing coach via the setUserRole Cloud Function.
      //
      // The hardcoded `Y9DlGI9kF6dPFPBh4cDvMnxbayB3` (Coach Zaki) clause
      // is the last line of defense: when both his custom claim and his
      // Firestore role lookup fail (token freshly minted, doc in-flight,
      // mirror not yet written), coach-only write paths would silently
      // degrade and admin tools would look broken to him. With this
      // anchor he stays staff under all conditions; the only way to
      // strip his staff access is to delete the UID itself.
      return request.auth != null && (
        request.auth.uid == 'Y9DlGI9kF6dPFPBh4cDvMnxbayB3'
        || request.auth.token.role in ['coach', 'admin']
        || role() in ['coach', 'admin']
      );
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Messaging is gated to the coaching tier — coach <-> paid client.
    // Community users use the public posts feed for questions; private
    // messaging is a paid-plan feature so the coach's inbox doesn't
    // get flooded by users with no coaching engagement. The hardcoded
    // Y9Dl branch matches isCoach() so the single-coach launch stays
    // intact even when role lookup is mid-resolve.
    function isCoachingTier() {
      return request.auth != null && (
        request.auth.uid == 'Y9DlGI9kF6dPFPBh4cDvMnxbayB3'
        || request.auth.token.role in ['coach', 'admin', 'client']
        || role() in ['coach', 'admin', 'client']
      );
    }

    // Belt-and-suspenders gate. Originally this was a heavy predicate:
    //   request.auth.token.disabled != true
    //   AND exists(users/{uid})
    //   AND get(users/{uid}).data.disabled != true
    //
    // Two failure modes traced this round:
    //   1) Stale `disabled: true` custom claim on a token issued before
    //      the user was un-banned (or before claims were set at all in
    //      a way Firestore could read consistently) → blanket denial
    //      across every rule that gated on isActive(): courses, videos,
    //      workouts, messages, the user's own doc-update path for FCM
    //      tokens. Symptom: "insufficient permissions" everywhere with
    //      no diagnostic surface.
    //   2) Brand-new sign-in whose users/{uid} doc was mid-write or
    //      missing → exists() returned false, blanket denial.
    //
    // The defenses we ACTUALLY rely on for banned users:
    //   - setUserDisabled Cloud Function calls revokeRefreshTokens, so
    //     the next token refresh signs them out at the SDK level.
    //   - AuthContext's live snapshot on users/{uid} sees disabled=true
    //     and signs them out client-side immediately.
    //   - deletionLogs/{uid} tombstone in AuthContext.signIn blocks
    //     resurrected accounts at sign-in.
    //
    // None of those need the rules layer to also do a Firestore-doc
    // round-trip on every read. Reducing isActive() to "is signed in"
    // restores the rest of the rule chain without losing the actual
    // ban enforcement.
    function isActive() {
      return request.auth != null;
    }

    function isValidString(s, maxLen) {
      return s is string && s.size() > 0 && s.size() <= maxLen;
    }

    function isValidMessageBody() {
      let hasText = request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 2000;
      let hasImage = ('imageUrl' in request.resource.data)
                     && request.resource.data.imageUrl is string
                     && request.resource.data.imageUrl.size() > 0
                     && request.resource.data.imageUrl.size() <= 2000
                     && request.resource.data.imagePath is string
                     && request.resource.data.imagePath.size() > 0
                     && request.resource.data.imagePath.size() <= 500;
      return request.resource.data.text is string
             && request.resource.data.text.size() <= 2000
             && (hasText || hasImage);
    }

    // Library catalog gate — active and signed in.
    function canAccessLibrary() {
      return isSignedIn() && isActive();
    }

    function canReadCourseData(course) {
      return course.isPublished == true
             && (course.accessTier == 'community'
                 || (course.accessTier == 'client' && role() == 'client'));
    }

    function completedLesson(courseId, lessonId) {
      let progressId = request.auth.uid + '_' + courseId + '_' + lessonId;
      return exists(/databases/$(database)/documents/userLessonProgress/$(progressId))
             && get(/databases/$(database)/documents/userLessonProgress/$(progressId)).data.status == 'completed';
    }

    function canReadLessonMetadata(courseId) {
      let course = get(/databases/$(database)/documents/courses/$(courseId)).data;
      return isCoach() || canReadCourseData(course);
    }

    function canReadLessonContentData(courseId, lesson) {
      let course = get(/databases/$(database)/documents/courses/$(courseId)).data;
      return isCoach()
             || (course.isPublished == true
                 && (lesson.isPreview == true
                     || (canReadCourseData(course)
                         && (lesson.isRequired != true
                             || lesson.order <= 1
                             || (lesson.prerequisiteLessonId is string
                                 && completedLesson(courseId, lesson.prerequisiteLessonId))))));
    }

    function canReadLessonContentId(courseId, lessonId) {
      let lesson = get(/databases/$(database)/documents/courses/$(courseId)/lessons/$(lessonId)).data;
      return canReadLessonContentData(courseId, lesson);
    }

    function isValidLessonMetadata() {
      return request.resource.data.keys().hasOnly(
               ['title', 'description', 'thumbnailUrl', 'order', 'durationMinutes',
                'isRequired', 'isPreview', 'prerequisiteLessonId', 'hasContent',
                'createdBy', 'createdAt', 'updatedAt', 'archived']);
    }

    function isValidLessonContent(courseId, lessonId) {
      return request.resource.data.keys().hasOnly(
               ['id', 'lessonId', 'courseId', 'videoUrl', 'platform', 'resources', 'updatedAt'])
             && request.resource.data.id == lessonId
             && request.resource.data.lessonId == lessonId
             && request.resource.data.courseId == courseId;
    }

    function isValidLessonProgressWrite(progressId) {
      return request.resource.data.keys().hasOnly(
               ['id', 'userId', 'courseId', 'lessonId', 'status',
                'startedAt', 'completedAt', 'updatedAt'])
             && request.resource.data.id == progressId
             && request.resource.data.userId == request.auth.uid
             && request.resource.data.status in ['started', 'completed']
             && request.resource.data.courseId is string
             && request.resource.data.lessonId is string
             && canReadLessonContentId(request.resource.data.courseId, request.resource.data.lessonId);
    }

    // ─── publicProfiles/{uid} ──────────────────────────────────
    // Public projection used by the leaderboard. Server-only writes:
    // every field on this doc is set by Cloud Functions (`awardXp`,
    // `setUserRole`, `setUserDisabled`). No client-side mutations.
    match /publicProfiles/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ─── users/{uid} ──────────────────────────────────────────
    // Server-controlled fields:
    //   - role           → setUserRole Cloud Function
    //   - disabled       → setUserDisabled Cloud Function
    //   - disabledAt     → setUserDisabled
    //   - disabledBy     → setUserDisabled
    //   - activityScore  → awardXp
    //   - streak         → awardXp
    //   - lastActiveAt   → awardXp
    // Owner can update any other field on their own doc (display name,
    // theme, profile bits). Coach can read all but mutates roles/disabled
    // ONLY through the callable functions.
    match /users/{uid} {
      allow read: if isSignedIn() && (isOwner(uid) || isCoach());
      // Self-create is locked to a community-level seed doc — closes the
      // privilege-escalation hole (a signed-in user could write
      // role:'admin' to their own users doc and gain coach access via
      // the rules' Firestore-role fallback). Coaches/admins keep wide
      // create powers (used by the AddClient flow).
      allow create: if isSignedIn() && (
        (isOwner(uid)
          && request.resource.data.role == 'community'
          && request.resource.data.disabled != true
          && (!('activityScore' in request.resource.data)
              || request.resource.data.activityScore == 0))
        || isCoach()
      );
      allow delete: if false; // deletions go through deleteUser Cloud Function
      allow update: if isSignedIn() && isOwner(uid)
                    && !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny([
                           'role', 'disabled', 'disabledAt', 'disabledBy',
                           'activityScore', 'streak', 'lastActiveAt',
                         ]);

      // ── selfLogs subcollection (LEGACY) ─────────────────────
      // Old combined collection for weight + measurements + metrics. New
      // writes go to /weighIns and /metrics below. Kept here so historical
      // entries still render in charts; not used for new submissions.
      match /selfLogs/{logId} {
        allow read: if isSignedIn() && (isOwner(uid) || isCoach());
        allow create: if isSignedIn() && isOwner(uid)
                              && request.resource.data.keys().hasOnly(
                                   ['date', 'weight', 'measurements', 'metrics', 'notes',
                                    'period', 'weekStart', 'weekIndex', 'locked',
                                    'createdAt', 'updatedAt']);
        allow update: if isSignedIn() && isOwner(uid)
                              && resource.data.locked != true
                              && request.resource.data.keys().hasOnly(
                                   ['date', 'weight', 'measurements', 'metrics', 'notes',
                                    'period', 'weekStart', 'weekIndex', 'locked',
                                    'createdAt', 'updatedAt']);
        allow delete: if isSignedIn() && isOwner(uid) && resource.data.locked != true;
      }

      // ── weighIns subcollection ──────────────────────────────
      // Weekly weigh-ins. One doc per submission, keyed by the YYYY-MM-DD
      // date. `locked: true` is set on create — Firestore then blocks
      // updates/deletes (server-side guarantee that a submitted week stays
      // submitted). Cadence: 7-day rolling window enforced client-side; the
      // rule below ensures the lock can never be flipped back to false.
      match /weighIns/{date} {
        allow read: if isSignedIn() && (isOwner(uid) || isCoach());
        allow create: if isSignedIn() && isOwner(uid)
                              && request.resource.data.keys().hasOnly(
                                   ['weight', 'weekStart', 'locked', 'createdAt']);
        allow update: if isSignedIn() && isOwner(uid)
                              && resource.data.locked != true
                              && request.resource.data.keys().hasOnly(
                                   ['weight', 'weekStart', 'locked', 'createdAt']);
        allow delete: if isSignedIn() && isOwner(uid) && resource.data.locked != true;
      }

      // ── metrics subcollection ───────────────────────────────
      // Subjective + cardio metrics submitted alongside the weigh-in.
      // Always written in the same client batch as /weighIns so the two
      // stay in lockstep. Same lock semantics — `locked: true` is set on
      // create, the rule blocks subsequent edits.
      match /metrics/{date} {
        allow read: if isSignedIn() && (isOwner(uid) || isCoach());
        allow create: if isSignedIn() && isOwner(uid)
                              && request.resource.data.keys().hasOnly(
                                   ['strength', 'hunger', 'energy', 'cardioCalories',
                                    'notes', 'weekStart', 'locked', 'createdAt']);
        allow update: if isSignedIn() && isOwner(uid)
                              && resource.data.locked != true
                              && request.resource.data.keys().hasOnly(
                                   ['strength', 'hunger', 'energy', 'cardioCalories',
                                    'notes', 'weekStart', 'locked', 'createdAt']);
        allow delete: if isSignedIn() && isOwner(uid) && resource.data.locked != true;
      }
    }

    // ─── clients/{clientId} ───────────────────────────────────
    match /clients/{clientId} {
      allow read: if isSignedIn()
                  && (resource.data.userId == request.auth.uid || isCoach());
      allow create, delete: if isSignedIn() && isCoach();
      allow update: if isSignedIn()
                    && (isCoach()
                        // Onboarding: client can update their own doc but not coach-managed fields
                        || (resource.data.userId == request.auth.uid
                            && resource.data.isOnboarding == true
                            && !request.resource.data.diff(resource.data)
                                 .affectedKeys().hasAny(['programLength', 'coachId', 'userId']))
                        // Post-onboarding: stricter — also lock currentWeek
                        || (resource.data.userId == request.auth.uid
                            && resource.data.isOnboarding != true
                            && !request.resource.data.diff(resource.data)
                                 .affectedKeys().hasAny(['currentWeek', 'programLength', 'coachId', 'userId'])));
    }

    // ─── checkIns/{checkInId} ─────────────────────────────────
    match /checkIns/{checkInId} {
      allow read: if isSignedIn()
                  && (resource.data.clientId == request.auth.uid || isCoach());

      // Client can only create a checkIn for themselves; also enforce userId matches
      allow create: if isSignedIn()
                    && (isCoach()
                        || (request.resource.data.clientId == request.auth.uid
                            && request.resource.data.userId == request.auth.uid));

      allow delete: if isSignedIn() && isCoach();

      // Clients cannot touch coach-only fields. They CAN flip status from
      // 'pending' to 'submitted' to submit their week (no other status changes).
      allow update: if isSignedIn()
                    && (isCoach()
                        || (resource.data.clientId == request.auth.uid
                            && !request.resource.data.diff(resource.data).affectedKeys()
                                 .hasAny(['coachFeedback', 'newMacros', 'newTargets', 'activeTargets'])
                            && (
                                 // Status unchanged
                                 request.resource.data.status == resource.data.status
                                 // OR transitioning pending → submitted
                                 || (resource.data.status == 'pending'
                                     && request.resource.data.status == 'submitted')
                               )));
    }

    // ─── videos/{videoId} ─────────────────────────────────────
    // Legacy flat-video collection (being phased out — new content uploads
    // via courses). Keeps the original isLocked model: community sees only
    // unlocked videos, clients+coaches see everything. Coach-only writes.
    match /videos/{videoId} {
      allow read: if canAccessLibrary();
      allow create, update, delete: if isSignedIn() && isCoach();
    }

    // ─── workouts/{workoutId} ─────────────────────────────────
    // Shared catalog: all signed-in active users see every workout. Writes
    // coach-only.
    match /workouts/{workoutId} {
      allow read: if canAccessLibrary();
      allow write: if isSignedIn() && isCoach();
    }

    // ─── messages/{messageId} ─────────────────────────────────
    // Coaching-tier only: community users cannot read, create, or
    // update message docs. Coaches can load the full inbox so legacy
    // admin-addressed history remains visible; clients stay scoped to
    // conversations where they are sender or receiver.
    match /messages/{messageId} {
      allow read: if isCoachingTier()
                  && (isCoach()
                      || resource.data.senderId == request.auth.uid
                      || resource.data.receiverId == request.auth.uid);

      allow create: if isCoachingTier()
                    && request.resource.data.senderId == request.auth.uid
                    && request.resource.data.receiverId is string
                    && request.resource.data.senderName is string
                    && isValidMessageBody();

      // Only mark-as-read updates allowed for the receiver.
      allow update: if isCoachingTier()
                    && resource.data.receiverId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      allow delete: if isSignedIn() && isCoach();
    }

    // ─── posts/{postId} ───────────────────────────────────────
    match /posts/{postId} {
      allow read: if isSignedIn() && isActive();

      // authorId must match caller; authorRole must match caller's actual role
      // (prevents spoofing e.g. a community member posting as 'coach')
      allow create: if isSignedIn() && isActive()
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.authorRole == role()
                    && isValidString(request.resource.data.content, 5000);

      allow update: if isSignedIn() && isActive()
                    && (
                      isCoach()
                      || (
                        resource.data.authorId == request.auth.uid
                        && !request.resource.data.diff(resource.data).affectedKeys()
                             .hasAny(['authorId', 'authorRole', 'commentCount'])
                      )
                      // Like-toggle for non-author non-coach: only the
                      // `likes` array may change, no duplicates, set
                      // diff must equal exactly the caller's own uid
                      // (add or remove). commentCount is server-only —
                      // maintained by the onCommentCreated/Deleted
                      // triggers (functions/src/maintainCommentCount.ts).
                      || (
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
                        && request.resource.data.likes.size() == request.resource.data.likes.toSet().size()
                        && (
                          request.resource.data.likes.toSet()
                            == resource.data.likes.toSet().union([request.auth.uid].toSet())
                          || request.resource.data.likes.toSet()
                            == resource.data.likes.toSet().difference([request.auth.uid].toSet())
                        )
                      )
                    );

      allow delete: if isSignedIn() && isActive()
                    && (isCoach() || resource.data.authorId == request.auth.uid);

      // ── comments ────────────────────────────────────────────
      match /comments/{commentId} {
        allow read: if isSignedIn() && isActive();

        allow create: if isSignedIn() && isActive()
                      && request.resource.data.authorId == request.auth.uid
                      && isValidString(request.resource.data.content, 1000);

        allow update: if isSignedIn() && isActive()
                      && (isCoach() || resource.data.authorId == request.auth.uid);

        allow delete: if isSignedIn() && isActive()
                      && (isCoach() || resource.data.authorId == request.auth.uid);
      }
    }

    // ─── libraryTags/{tagId} ──────────────────────────────────
    match /libraryTags/{tagId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isCoach();
    }

    // ─── libraryCategories/{categoryId} ───────────────────────
    match /libraryCategories/{categoryId} {
      allow read: if canAccessLibrary();
      allow create, update, delete: if isSignedIn() && isCoach();
    }

    // ─── courses/{courseId} ───────────────────────────────────
    // Shared catalog model: course + lesson METADATA (title, cover image,
    // description, lesson count, duration) visible to every active
    // signed-in user — community + client both browse the same library.
    // lessonContent (videoUrl, embed, PDFs) is gated by accessTier:
    //   - community-tier courses → everyone plays
    //   - client-tier courses    → community sees the card with a lock
    //                              badge; only clients+ can play
    match /courses/{courseId} {
      allow read: if canAccessLibrary();
      allow create, update, delete: if isSignedIn() && isCoach();

      match /lessons/{lessonId} {
        allow read: if canAccessLibrary();
        allow create: if isSignedIn() && isCoach() && isValidLessonMetadata();
        allow update: if isSignedIn() && isCoach() && isValidLessonMetadata();
        allow delete: if isSignedIn() && isCoach();
      }

      match /lessonContent/{lessonId} {
        // Same gate as the catalog — any active signed-in user can read.
        // Per-tier paywall gating (community can't watch client-tier
        // videos) is enforced client-side via VideoLibrary's canAccessCourse
        // for now; firmer rule-level gating waits until post-launch when
        // we can test multi-role get() chains without launch pressure.
        allow read: if canAccessLibrary();
        allow create, update: if isSignedIn() && isCoach() && isValidLessonContent(courseId, lessonId);
        allow delete: if isSignedIn() && isCoach();
      }
    }

    // ─── userLessonProgress/{progressId} ─────────────────────
    // progressId = "{userId}_{courseId}_{lessonId}"
    match /userLessonProgress/{progressId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isCoach());
      allow create: if isSignedIn()
                    && progressId == request.auth.uid + '_' + request.resource.data.courseId + '_' + request.resource.data.lessonId
                    && isValidLessonProgressWrite(progressId);
      allow update: if isSignedIn()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.courseId == resource.data.courseId
                    && request.resource.data.lessonId == resource.data.lessonId
                    && isValidLessonProgressWrite(progressId);
      allow delete: if false;
    }

    // ─── userCourseProgress/{progressId} ─────────────────────
    // Legacy summary collection; course progress is now derived from userLessonProgress.
    match /userCourseProgress/{progressId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isCoach());
      allow create, update: if isSignedIn() && isCoach();
      allow delete: if false;
    }

    // ─── settings/{docId} ─────────────────────────────────────
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isCoach();
    }

    // ─── dietCovers/{dietId} ──────────────────────────────────
    // Coach-uploaded cover-image overlays for the static diet catalog.
    // Read by useDietCovers (any signed-in user). Coach-only writes.
    match /dietCovers/{dietId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isCoach();
    }

    // ─── auditLog/{logId} ─────────────────────────────────────
    // Coach-only audit trail. Append-only — no updates or deletes.
    match /auditLog/{logId} {
      allow read, create: if isSignedIn() && isCoach();
      allow update, delete: if false;
    }

    // ─── deletionLogs/{uid} ───────────────────────────────────
    // Per-user deletion log written when coach bans a community member.
    // One doc per banned uid (overwritable on re-ban). Owner can read their
    // own tombstone (the AuthContext sign-in tombstone gate needs this);
    // create/update remain coach-only.
    match /deletionLogs/{uid} {
      allow read: if isSignedIn() && (isOwner(uid) || isCoach());
      allow create, update: if isSignedIn() && isCoach();
      allow delete: if false;
    }

    // ─── userPrograms/{userId} ────────────────────────────────
    // Stores each user's active training program.
    // Users manage their own; coaches can assign to any user.
    match /userPrograms/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isCoach());
      allow write: if isSignedIn() && (isOwner(userId) || isCoach());
    }

    // ─── userDiets/{userId} ───────────────────────────────────
    // Stores each user's currently-assigned diet plan.
    // Owner self-assigns via the diet wizard; coaches assign + swap on
    // weekly check-in. Mirrors userPrograms — same trust model, no
    // shape constraint (the snapshot insulates the user from catalog edits).
    match /userDiets/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isCoach());
      allow write: if isSignedIn() && (isOwner(userId) || isCoach());
    }

    // ─── audienceProfiles/{anonId} ────────────────────────────
    // Post-deletion ICP analytics snapshots. Written ONLY by the
    // deleteUser Cloud Function (server-side admin SDK bypasses these
    // rules). Coaches/admins can read for analytics; nobody can write
    // or delete from the client SDK. The anonId is a random id, NOT
    // the original uid — re-identification is impossible by design.
    match /audienceProfiles/{anonId} {
      allow read: if isCoach();
      allow write: if false;
    }
  }
}
